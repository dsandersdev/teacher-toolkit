# Auto detect text files
* text=auto

# Python
*.py text eol=lf

# JavaScript / React
*.js text eol=lf
*.jsx text eol=lf

# CSS
*.css text eol=lf

# HTML
*.html text eol=lf

# JSON
*.json text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.ps1 text eol=crlf